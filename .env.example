# Configure only the provider keys you use.
# Built-in providers: openrouter, openai, anthropic, deepseek, glm
# Custom providers: see ~/.furnace/providers.json
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=

# Optional: override the default model, app name, or site URL
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-6
# OPENROUTER_APP_NAME=Furnace
# OPENROUTER_SITE_URL=http://localhost

# Optional: title generation model (defaults to openai/gpt-4o-mini)
# OPENROUTER_TITLE_MODEL=openai/gpt-4o-mini

# Optional: terminal layout override
# FURNACE_LAYOUT=classic
# FURNACE_THEME=gruvbox
