{
  "name": "cook-furnace",
  "version": "0.1.9",
  "description": "A from-scratch harness for agentic coding.",
  "type": "module",
  "bin": {
    "furnace": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "dist/prompts/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "check-node": "./scripts/with-node22.sh node scripts/ensure-node-version.mjs",
    "dev": "./scripts/with-node22.sh tsx src/cli.ts",
    "build": "./scripts/with-node22.sh sh -c 'node scripts/clean-dist.mjs && tsc -p tsconfig.json && node scripts/copy-prompts.mjs && esbuild src/cli.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/cli.js --banner:js=\"import { createRequire } from \\\"node:module\\\";const require = createRequire(import.meta.url);\" --external:better-sqlite3 --external:@earendil-works/pi-tui'",
    "start": "./scripts/with-node22.sh node dist/cli.js",
    "typecheck": "./scripts/with-node22.sh tsc -p tsconfig.json --noEmit",
    "test": "npm run build && ./scripts/with-node22.sh node --test",
    "pack:dry-run": "npm pack --dry-run --ignore-scripts",
    "verify": "node scripts/verify-before-push.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm run pack:dry-run"
  },
  "keywords": [
    "ai",
    "agent",
    "coding-agent",
    "cli",
    "tui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amoreX/furnace.git"
  },
  "bugs": {
    "url": "https://github.com/amoreX/furnace/issues"
  },
  "homepage": "https://github.com/amoreX/furnace#readme",
  "dependencies": {
    "@earendil-works/pi-tui": "0.80.3",
    "better-sqlite3": "^12.11.1",
    "chalk": "5.6.2",
    "commander": "^14.0.2",
    "diff": "^9.0.0",
    "dotenv": "^17.2.3",
    "highlight.js": "^11.11.1",
    "htmlparser2": "^12.0.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/turndown": "^5.0.6",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.19.0 <23"
  }
}
