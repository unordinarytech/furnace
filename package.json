{
  "name": "furnace",
  "version": "0.0.0",
  "description": "A from-scratch harness for agentic coding.",
  "type": "module",
  "bin": {
    "furnace": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-prompts.mjs && esbuild src/cli.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/cli.js --banner:js='import { createRequire } from \"node:module\";const require = createRequire(import.meta.url);' --external:better-sqlite3 --external:react-devtools-core",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test"
  },
  "keywords": [
    "ai",
    "agent",
    "coding-agent",
    "cli",
    "tui"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cli-spinners": "^3.4.0",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "htmlparser2": "^12.0.0",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "supports-hyperlinks": "^4.5.0",
    "turndown": "^7.2.4",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/turndown": "^5.0.6",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
